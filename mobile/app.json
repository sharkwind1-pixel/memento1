{
  "expo": {
    "name": "메멘토애니",
    "slug": "mementoani",
    "version": "1.0.0",
    "description": "반려동물과 보내는 평생의 일상을 기록하고 돌보는 반려동물 라이프 플랫폼. 매일의 순간과 케어, AI 펫톡부터 오랜 시간이 흐른 뒤의 추억까지 함께해요.",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "mementoani",
    "primaryColor": "#05B2DC",
    "assetBundlePatterns": ["**/*"],
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#E0F7FF"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.mementoani.app",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "반려동물 사진을 업로드하기 위해 갤러리에 접근합니다.",
        "NSCameraUsageDescription": "반려동물 사진을 촬영하기 위해 카메라에 접근합니다.",
        "NSMicrophoneUsageDescription": "동영상 촬영 시 마이크에 접근합니다.",
        "NSLocationWhenInUseUsageDescription": "AI 펫톡에서 근처 산책로/병원/펫카페를 추천하기 위해 위치를 사용합니다.",
        "LSApplicationQueriesSchemes": [
          "ispmobile",
          "kakaopay",
          "kakaotalk",
          "kftc-bankpay",
          "mpocket.online.ansimclick",
          "kb-acp",
          "shinhan-sr-ansimclick",
          "hdcardappcardansimclick",
          "smshinhanansimclick",
          "smhanaansim",
          "smshinhancardusimansim",
          "lottesmartpay",
          "lotteappcard",
          "cloudpay",
          "payco",
          "samsungpay",
