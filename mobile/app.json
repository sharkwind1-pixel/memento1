          "wooripay",
          "newliivbank",
          "kakaobank",
          "supertoss",
          "naversearchapp",
          "tmoneypay",
          "newsmartpay",
          "ispmobile",
          "kakaopay",
          "kakaotalk",
          "kftc-bankpay",
          "mpocket.online.ansimclick",
          "kb-acp",
          "shinhan-sr-ansimclick",
          "hdcardappcardansimclick",
          "smshinhanansimclick",
          "smhanaansim",
          "smshinhancardusimansim",
          "lottesmartpay",
          "lotteappcard",
          "cloudpay",
          "payco",
          "samsungpay",
          "lpayapp",
          "smdmbapp",
          "nhappcardansimclick",
          "citimobileapp",
          "citispay",
          "kb-acp",
          "wooripay",
          "newliivbank",
          "kakaobank",
          "supertoss",
          "naversearchapp",
          "tmoneypay",
          "newsmartpay"
        ],
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#E0F7FF"
      },
      "package": "com.mementoani.app",
      "versionCode": 1,
      "permissions": [
        "INTERNET",
        "CAMERA",
        "READ_MEDIA_IMAGES",
        "READ_MEDIA_VIDEO",
        "POST_NOTIFICATIONS",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "RECORD_AUDIO"
      ],
      "blockedPermissions": [
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ],
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#05B2DC"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "반려동물 사진을 업로드하기 위해 갤러리에 접근합니다.",
          "cameraPermission": "반려동물 사진을 촬영하기 위해 카메라에 접근합니다."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "AI 펫톡에서 근처 산책로·동물병원·펫카페를 찾기 위해 현재 위치가 필요해요.",
          "locationAlwaysAndWhenInUsePermission": "AI 펫톡에서 근처 산책로·동물병원·펫카페를 찾기 위해 현재 위치가 필요해요.",
          "isIosBackgroundLocationEnabled": false,
          "isAndroidBackgroundLocationEnabled": false
        }
      ],
      "expo-web-browser",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "240e8f90-7a8a-4ba4-9422-d82a37842afd"
      }
    },
    "owner": "sharkwind1",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/240e8f90-7a8a-4ba4-9422-d82a37842afd"
    }
  }
