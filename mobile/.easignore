# EAS Build archive에서 제외할 파일 패턴
# 목적: archive 사이즈 줄이고 업로드 빠르게 (164MB → 30~50MB 예상)

# 의존성 (EAS가 빌드 머신에서 npm install 새로 함)
node_modules/

# 빌드 출력
.expo/
dist/
build/
web-build/

# 캐시
.metro-health-check*
.next/

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo

# 로컬 환경 (EAS는 EAS Secrets 사용)
.env*.local
.env.development
.env.test

# Git
.git/
.gitignore

# 문서/노트 (앱 빌드와 무관)
HANDOVER*.md
NOTES*.md
README*.md
*.log

# 테스트 (EAS 빌드는 테스트 안 돌림)
__tests__/
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx
coverage/

# 부모 디렉토리의 웹 코드 (mobile 빌드와 무관)
../src/
../public/
../.next/
../node_modules/

# EAS 크레덴셜 파일 (절대 archive 포함 금지)
google-play-key.json
*-service-account.json
appstore-connect-api-key.p8
