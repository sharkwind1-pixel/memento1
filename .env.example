# ============================================================
# 메멘토애니 (Memento Ani) 환경변수
# 이 파일을 .env.local로 복사한 뒤 실제 값을 채워주세요.
# cp .env.example .env.local
# ============================================================

# ------------------------------------------------------------
# Supabase (클라이언트 노출 - NEXT_PUBLIC_ prefix)
# https://supabase.com/dashboard → Settings → API
# ------------------------------------------------------------

# Supabase 프로젝트 URL (클라이언트에 노출됨)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase 익명(anon) 키 - RLS로 보호됨 (클라이언트에 노출됨)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ------------------------------------------------------------
# Supabase (서버 전용 - 절대 클라이언트에 노출 금지)
# ------------------------------------------------------------

# Supabase Service Role 키 - RLS를 우회하므로 서버에서만 사용
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ------------------------------------------------------------
# OpenAI
# https://platform.openai.com/api-keys
# ------------------------------------------------------------

# AI 펫톡, 매거진 자동 생성, 일일 인사 등에 사용 (GPT-4o-mini)
OPENAI_API_KEY=sk-your-openai-api-key

# ------------------------------------------------------------
# fal.ai (AI 영상 생성)
# https://fal.ai/dashboard/keys
# ------------------------------------------------------------

# fal.ai API 키 - AI 영상 생성 서비스에 사용
FAL_KEY=your-fal-ai-key

# ------------------------------------------------------------
# 영상 Webhook
# ------------------------------------------------------------

# fal.ai 영상 생성 완료 시 webhook 인증용 시크릿 (임의 문자열)
VIDEO_WEBHOOK_SECRET=your-random-webhook-secret

# ------------------------------------------------------------
# Web Push / VAPID
# web-push generate-vapid-keys 명령으로 생성
# ------------------------------------------------------------

# VAPID 공개키 - 브라우저 푸시 구독에 사용 (클라이언트에 노출됨)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key

# VAPID 비밀키 - 서버에서 푸시 알림 전송 시 사용
VAPID_PRIVATE_KEY=your-vapid-private-key

# VAPID 연락처 (기본값: mailto:support@memento-ani.com)
VAPID_SUBJECT=mailto:support@memento-ani.com

# ------------------------------------------------------------
# 네이버 OAuth (소셜 로그인 + 검색 API)
# https://developers.naver.com/apps
# ------------------------------------------------------------

# 네이버 로그인 Client ID (검색 API에도 사용)
NAVER_CLIENT_ID=your-naver-client-id

# 네이버 로그인 Client Secret (검색 API에도 사용)
NAVER_CLIENT_SECRET=your-naver-client-secret

# ------------------------------------------------------------
# 네이버 클라우드 플랫폼 (NCP) - 위치 기반 장소 추천
# https://www.ncloud.com → 콘솔 → AI/Application → Maps
# Reverse Geocoding API용 (GPS 좌표 → 행정구역명 변환)
# ------------------------------------------------------------

# NCP Application Client ID
NAVER_NCP_CLIENT_ID=your-ncp-client-id

# NCP Application Client Secret
NAVER_NCP_CLIENT_SECRET=your-ncp-client-secret

# ------------------------------------------------------------
# 외부 API 키
# ------------------------------------------------------------

# 공공데이터포털 API 키 - 입양정보 조회 (없으면 목업 데이터 반환)
# https://www.data.go.kr
OPENDATA_API_KEY=your-opendata-api-key

# Unsplash API Access Key - 매거진 이미지 (없으면 폴백 이미지 사용)
# https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=your-unsplash-access-key

# ipinfo.io 토큰 - IP 기반 VPN/프록시 감지 (선택사항)
# https://ipinfo.io/account/token
IPINFO_TOKEN=your-ipinfo-token

# ------------------------------------------------------------
# 사이트 URL
# ------------------------------------------------------------

# 사이트 공개 URL - SEO(robots.txt, sitemap), 네이버 OAuth 콜백 등에 사용 (클라이언트에 노출됨)
# 기본값: https://mementoani.com
NEXT_PUBLIC_SITE_URL=https://mementoani.com

# 앱 URL - 영상 생성 webhook URL 구성에 사용 (클라이언트에 노출됨)
# 기본값: https://memento1.vercel.app
NEXT_PUBLIC_APP_URL=https://memento1.vercel.app

# ------------------------------------------------------------
# 포트원 결제 (PortOne V2)
# https://admin.portone.io/
# ------------------------------------------------------------

# 포트원 Store ID - 관리자 콘솔 상단에서 확인 (클라이언트에 노출됨)
NEXT_PUBLIC_PORTONE_STORE_ID=your-portone-store-id

# 포트원 채널 키 - 결제 연동 > 연동 관리에서 확인 (클라이언트에 노출됨)
NEXT_PUBLIC_PORTONE_CHANNEL_KEY=your-portone-channel-key

# 포트원 V1 REST API Key - 결제 검증 토큰 발급에 사용 (서버 전용)
PORTONE_REST_API_KEY=your-portone-rest-api-key

# 포트원 V1 REST API Secret - 결제 검증에 사용 (서버 전용, 절대 클라이언트 노출 금지)
PORTONE_API_SECRET=your-portone-api-secret

# 카카오 JavaScript SDK (공유 기능)
NEXT_PUBLIC_KAKAO_APP_KEY=your-kakao-javascript-key

# ------------------------------------------------------------
# Cron Job 보안
# ------------------------------------------------------------

# Vercel Cron 인증 시크릿 - cron 엔드포인트 무단 호출 방지 (임의 문자열)
CRON_SECRET=your-random-cron-secret

# ------------------------------------------------------------
# Tavily (AI 케어 검색 RAG)
# https://tavily.com
# ------------------------------------------------------------

# Tavily API 키 - AI 펫톡 케어 질문 시 웹 검색 RAG에 사용
TAVILY_API_KEY=your-tavily-api-key

# ------------------------------------------------------------
# 텔레그램 관리자 알림 봇
# @BotFather에서 봇 생성 후 토큰과 chat ID 입력
# ------------------------------------------------------------

# 텔레그램 봇 토큰 (서버 전용)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# 기본 chat ID (폴백용)
TELEGRAM_CHAT_ID=your-telegram-chat-id

# 채널별 그룹 chat ID (그룹은 -로 시작하는 숫자)
TELEGRAM_CHAT_REPORT=your-report-group-chat-id
TELEGRAM_CHAT_PAYMENT=your-payment-group-chat-id
TELEGRAM_CHAT_SYSTEM=your-system-group-chat-id
